---
import { faqs } from "../../content/data/faqs";
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const featuredFaqs = [
  "Does ranking a second choice hurt my first choice?",
  "Has Melrose adopted RCV yet?",
  "How much would implementation cost?",
  "How can I help?",
]
  .map((title) => faqs.find((faq) => faq.title === title))
  .filter(Boolean);
---

<section class="bg-[var(--color-blue-50)]">
  <div class="section-shell py-12">
    <SectionHeading
      eyebrow="FAQ"
      title="Quick answers for common next questions"
      summary="The full FAQ keeps legal, cost, timing, and implementation uncertainty visible."
    />
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {featuredFaqs.map((faq) => (
        <article class="rounded-[var(--radius-4)] border border-[var(--color-blue-100)] bg-white p-5 shadow-[var(--shadow-xs)]">
          <h3 class="m-0 text-lg font-black">{faq.title}</h3>
          <p class="mt-3 text-sm leading-[var(--leading-normal)] text-[var(--color-ink-soft)]">{faq.summary}</p>
        </article>
      ))}
    </div>
    <div class="mt-7 flex flex-wrap gap-3">
      <Button href="/faq" variant="secondary">Read the full FAQ</Button>
      <Button href="/contact" variant="ghost">Ask a question</Button>
    </div>
  </div>
</section>
