---
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";
---

<section class="bg-[var(--color-civic-paper)]">
  <div class="section-shell grid gap-8 py-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
    <div>
      <Badge label="Nonpartisan civic education" />
      <h1 class="mt-5 max-w-4xl text-4xl font-bold leading-tight text-[var(--color-civic-ink)] md:text-5xl">
        Melrose RCV
      </h1>
      <p class="mt-5 max-w-2xl text-xl text-slate-700">
        A starter website scaffold for learning about ranked-choice voting and the Massachusetts home rule petition pathway.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <Button href="/what-is-rcv">Start learning</Button>
        <Button href="/home-rule-petition" variant="secondary">Review the pathway</Button>
      </div>
    </div>
    <div class="rounded-sm border border-[var(--color-civic-line)] bg-white p-6 shadow-sm">
      <p class="m-0 text-sm font-semibold uppercase tracking-normal text-[var(--color-civic-green)]">Scaffold status</p>
      <p class="mt-3 text-2xl font-bold">Placeholder content only</p>
      <p class="mt-3 text-slate-700">
        Future work should add verified sources, reviewed legal language, polished diagrams, and final resident-facing copy.
      </p>
    </div>
  </div>
</section>
