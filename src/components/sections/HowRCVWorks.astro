---
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const steps = [
  {
    label: "Step 1",
    title: "First choices are counted",
    summary: "The count starts with each voter's first-ranked continuing candidate.",
  },
  {
    label: "Step 2",
    title: "Check the winning threshold",
    summary: "If a candidate meets the threshold under the rules, that candidate wins.",
  },
  {
    label: "Step 3",
    title: "Lowest candidate is eliminated",
    summary: "If no candidate meets the threshold, the candidate with the fewest votes is eliminated.",
  },
  {
    label: "Step 4",
    title: "Backup choices can transfer",
    summary: "Ballots for the eliminated candidate move to the next ranked continuing candidate.",
  },
];
---

<section id="how-it-works" class="section-band bg-[var(--color-blue-50)]">
  <div class="section-shell">
    <SectionHeading
      eyebrow="How it works"
      title="A runoff-style count from one ballot"
      summary="In a single-winner RCV election, a ballot counts for one continuing candidate at a time. Later rankings are backups, not extra votes."
    />
    <div class="mt-8 grid gap-4 lg:grid-cols-4">
      {steps.map((step, index) => (
        <article class="relative rounded-[var(--radius-4)] border border-[var(--color-blue-100)] bg-white p-5 shadow-[var(--shadow-xs)]">
          <p class="m-0 text-xs font-black uppercase text-[var(--color-blue-700)]">{step.label}</p>
          <h3 class="mt-3 text-xl font-black">{step.title}</h3>
          <p class="mt-3 text-sm leading-[var(--leading-normal)] text-[var(--color-ink-soft)]">{step.summary}</p>
          {index < steps.length - 1 && (
            <span class="absolute -right-3 top-1/2 hidden size-7 -translate-y-1/2 place-items-center rounded-[var(--radius-pill)] border border-[var(--color-blue-100)] bg-white text-[var(--color-blue-700)] lg:grid" aria-hidden="true">
              -&gt;
            </span>
          )}
        </article>
      ))}
    </div>
    <div class="mt-7 grid gap-4 lg:grid-cols-[1fr_0.78fr] lg:items-start">
      <div class="rounded-[var(--radius-4)] border border-[var(--color-line)] bg-white p-5 shadow-[var(--shadow-xs)]">
        <h3 class="text-xl font-black">The key promise and the key caveat</h3>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Ranking a backup choice does not hurt a first choice while the first choice remains in the count. If all ranked candidates are eliminated, a ballot may have no continuing choice in later rounds.
        </p>
      </div>
      <div class="rounded-[var(--radius-4)] border border-[var(--color-lilac-100)] bg-[var(--color-lilac-50)] p-5 text-[var(--color-lilac-800)]">
        <p class="m-0 text-sm font-black uppercase">Source note</p>
        <p class="mt-2 text-sm leading-[var(--leading-normal)]">
          Counting description is grounded in MIT Election Lab, NCSL, NYC Votes, and Boulder County examples. Melrose-specific ballot rules would need official review.
        </p>
      </div>
    </div>
    <div class="mt-7 flex flex-wrap gap-3">
      <Button href="/how-it-works">Go deeper on the count</Button>
      <Button href="#myths" variant="secondary">Check common concerns</Button>
    </div>
  </div>
</section>
