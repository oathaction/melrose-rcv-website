---
import SectionHeading from "../ui/SectionHeading.astro";

const checkpoints = [
  "Define the local proposal",
  "Review petition language",
  "Seek local public consideration",
  "File and review at the State House",
  "Plan implementation only if authorized",
];
---

<section class="bg-[var(--color-lilac-50)]">
  <div class="section-shell py-10">
    <SectionHeading
      eyebrow="No fixed timeline yet"
      title="A path, not a promise"
      summary="These checkpoints explain the kind of work ahead. They are not dates, deadlines, or a guarantee that RCV will be authorized."
    />
    <ol class="mt-6 grid gap-3 p-0 md:grid-cols-5">
      {checkpoints.map((checkpoint, index) => (
        <li class="list-none rounded-[var(--radius-3)] border border-[var(--color-lilac-100)] bg-white p-4">
          <span class="text-xs font-black uppercase text-[var(--color-lilac-800)]">Checkpoint {index + 1}</span>
          <p class="mt-2 text-sm font-bold text-[var(--color-ink)]">{checkpoint}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
