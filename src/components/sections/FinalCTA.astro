---
import Button from "../ui/Button.astro";
---

<section class="bg-[var(--color-civic-blue)] text-white">
  <div class="section-shell py-12">
    <h2 class="m-0 max-w-3xl text-3xl font-bold">Ready for the next phase</h2>
    <p class="mt-4 max-w-3xl text-blue-50">
      The scaffold is ready for research, review, and resident-facing content development.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <Button href="/sources" variant="secondary">Review source placeholders</Button>
      <Button href="/contact">Contact placeholder</Button>
    </div>
  </div>
</section>
