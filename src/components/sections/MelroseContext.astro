---
import SectionHeading from "../ui/SectionHeading.astro";
import SourceNote from "../ui/SourceNote.astro";
---

<section class="bg-[var(--color-green-50)]">
  <div class="section-shell grid gap-6 py-10 md:grid-cols-[1fr_0.8fr] md:items-center">
    <SectionHeading
      eyebrow="Melrose context"
      title="This is a local civic decision"
      summary="Melrose's City Council has 11 members: 4 councilors-at-large and 7 ward councilors. Which offices any RCV proposal would cover remains an open legal and policy question."
    />
    <SourceNote tone="verified" status="Council structure sourced to the Melrose Charter and Massachusetts Municipal Association profile; office scope still needs review." />
  </div>
</section>
