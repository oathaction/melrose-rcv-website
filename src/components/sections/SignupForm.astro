---
import { hasSignupEndpoint, signupFormConfig } from "../../lib/forms";
import Alert from "../ui/Alert.astro";
import Button from "../ui/Button.astro";
---

<section id="join" class="section-band bg-[var(--color-ink)] text-white">
  <div class="section-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <p class="m-0 text-sm font-black uppercase text-[var(--color-gold-100)]">Join the effort</p>
      <h2 class="mt-2 text-[clamp(2rem,5vw,3.5rem)] font-black text-white">Help Melrose have a careful RCV conversation</h2>
      <p class="mt-4 max-w-2xl text-lg leading-[var(--leading-normal)] text-slate-200">
        Join updates, volunteer, ask a question, share source-backed information, or support the effort once donation and compliance details are verified.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <Button href="/contact" variant="secondary">Ask a Question</Button>
        <Button href="/donate" variant="donation">Donate / Support</Button>
      </div>
    </div>
    <form class="grid gap-4 rounded-[var(--radius-4)] border border-white/15 bg-white p-5 text-[var(--color-ink)] shadow-[var(--shadow-sm)]" action={signupFormConfig.endpoint || "#join"} method={signupFormConfig.method}>
      <div>
        <h3 class="text-2xl font-black">Join the Melrose RCV list</h3>
        <p class="mt-2 text-sm text-[var(--color-ink-soft)]">Get updates about public education, source review, volunteer needs, and the home rule petition pathway.</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-[1fr_auto]">
        <label class="grid gap-2 text-sm font-bold">
          Email address
          <input class="min-h-12 rounded-[var(--radius-2)] border border-[var(--color-line-strong)] px-3 py-2 font-normal" type="email" name="email" placeholder="name@example.com" autocomplete="email" required disabled={!hasSignupEndpoint()} />
        </label>
        <div class="flex items-end">
          <Button type="submit" variant="support" class="w-full sm:w-auto">Join updates</Button>
        </div>
      </div>
      {!hasSignupEndpoint() && (
        <Alert title="Signup setup pending" tone="caution">
          <p class="m-0">Configure `PUBLIC_SIGNUP_FORM_ENDPOINT` before launch. The field is disabled until the endpoint and privacy process are ready.</p>
        </Alert>
      )}
    </form>
  </div>
</section>
