---
const trustItems = [
  "Nonpartisan",
  "Source-grounded",
  "Melrose-focused",
  "Not an official City election resource",
  "Not legal advice",
];
---

<section class="border-y border-[var(--color-line)] bg-white" aria-label="Trust and status">
  <div class="section-shell py-4">
    <ul class="m-0 flex flex-wrap gap-2 p-0">
      {trustItems.map((item) => (
        <li class="list-none rounded-[var(--radius-pill)] border border-[var(--color-line)] bg-[var(--color-paper)] px-3 py-1.5 text-xs font-black uppercase text-[var(--color-ink-soft)]">
          {item}
        </li>
      ))}
    </ul>
  </div>
</section>
