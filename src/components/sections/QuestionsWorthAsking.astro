---
const questions = [
  "Which offices would a proposal cover?",
  "Would single-seat and multi-seat offices need different methods?",
  "What voting equipment, software, staffing, and training would be needed?",
  "How would results, audits, recounts, and certification work?",
  "What would implementation cost?",
  "What information would skeptical residents need before deciding?",
];
---

<section id="questions" class="section-band bg-white">
  <div class="section-shell grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
    <div>
      <p class="eyebrow">Questions worth asking</p>
      <h2 class="mt-2 text-[clamp(1.8rem,4vw,2.75rem)] font-black">A trustworthy campaign makes room for hard questions</h2>
      <p class="mt-4 text-lg text-[var(--color-ink-soft)]">
        Support for RCV should grow from clear answers, not pressure. These questions need public discussion and official review.
      </p>
    </div>
    <ul class="m-0 grid gap-3 p-0 md:grid-cols-2">
      {questions.map((question, index) => (
        <li class="list-none rounded-[var(--radius-3)] border border-[var(--color-line)] bg-[var(--color-paper)] p-4">
          <span class="text-xs font-black uppercase text-[var(--color-gold-700)]">Open question {index + 1}</span>
          <p class="mt-2 text-sm font-bold leading-[var(--leading-normal)] text-[var(--color-ink)]">{question}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
