---
import { SITE_NAME, CONTACT_EMAIL } from "../../lib/constants";
import { navItems } from "../../content/data/nav";

const trustLinks = [
  { label: "Myths and Facts", href: "/myths-and-facts" },
  { label: "Sources", href: "/sources" },
  { label: "About", href: "/about" },
];
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-ink)] text-white">
  <div class="section-shell grid gap-8 py-10 md:grid-cols-[1fr_2fr]">
    <div>
      <p class="m-0 text-lg font-black">{SITE_NAME}</p>
      <p class="mt-3 max-w-prose text-sm leading-[var(--leading-normal)] text-slate-200">
        Nonpartisan civic education and community organizing for Melrose residents. This site is not an official City of Melrose election resource.
      </p>
      <p class="mt-3 text-sm">
        <a class="focus-ring rounded-[var(--radius-1)] text-white underline underline-offset-4 hover:text-[var(--color-gold-100)]" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2">
      <nav aria-label="Footer navigation">
        <p class="m-0 text-sm font-black uppercase tracking-normal text-slate-300">Explore</p>
        <ul class="mt-3 grid gap-2 p-0">
          {navItems.map((item) => (
            <li class="list-none">
              <a class="focus-ring rounded-[var(--radius-1)] text-sm text-slate-100 no-underline underline-offset-4 hover:text-white hover:underline" href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
      <nav aria-label="Trust and transparency navigation">
        <p class="m-0 text-sm font-black uppercase tracking-normal text-slate-300">Trust and sources</p>
        <ul class="mt-3 grid gap-2 p-0">
          {trustLinks.map((item) => (
            <li class="list-none">
              <a class="focus-ring rounded-[var(--radius-1)] text-sm text-slate-100 no-underline underline-offset-4 hover:text-white hover:underline" href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
