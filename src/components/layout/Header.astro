---
import { SITE_NAME } from "../../lib/constants";
import { navItems } from "../../content/data/nav";
---

<header class="border-b border-[var(--color-civic-line)] bg-white">
  <div class="section-shell flex flex-col gap-4 py-5 lg:flex-row lg:items-center lg:justify-between">
    <a class="focus-ring inline-flex w-fit items-center gap-3 rounded-sm font-semibold text-[var(--color-civic-ink)] no-underline" href="/">
      <span class="grid size-10 place-items-center rounded-sm bg-[var(--color-civic-blue)] text-sm font-bold text-white">RCV</span>
      <span>{SITE_NAME}</span>
    </a>
    <nav aria-label="Primary navigation">
      <ul class="flex flex-wrap gap-x-5 gap-y-2 p-0 text-sm font-medium">
        {navItems.map((item) => (
          <li class="list-none">
            <a class="focus-ring rounded-sm text-[var(--color-civic-ink)] underline-offset-4 hover:text-[var(--color-civic-blue)] hover:underline" href={item.href}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
