---
interface Props {
  title?: string;
}

const { title = "Placeholder" } = Astro.props;
---

<div class="rounded-sm border border-[var(--color-civic-gold)] bg-amber-50 p-4 text-sm text-slate-800" role="note">
  <p class="m-0 font-semibold">{title}</p>
  <div class="mt-2">
    <slot />
  </div>
</div>
