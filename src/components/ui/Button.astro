---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
}

const { href, variant = "primary" } = Astro.props;
const className =
  variant === "primary"
    ? "focus-ring inline-flex items-center justify-center rounded-sm bg-[var(--color-civic-blue)] px-5 py-3 text-sm font-semibold text-white no-underline shadow-sm hover:bg-[#17476f]"
    : "focus-ring inline-flex items-center justify-center rounded-sm border border-[var(--color-civic-blue)] px-5 py-3 text-sm font-semibold text-[var(--color-civic-blue)] no-underline hover:bg-white";
---

{href ? <a class={className} href={href}><slot /></a> : <button class={className} type="button"><slot /></button>}
