---
interface Props {
  eyebrow?: string;
  title: string;
  summary?: string;
  align?: "left" | "center";
  level?: 1 | 2 | 3;
}

const { eyebrow, title, summary, align = "left", level = 2 } = Astro.props;
const HeadingTag = `h${level}` as const;
const alignClass = align === "center" ? "mx-auto text-center" : "";
---

<div class:list={["max-w-3xl", alignClass]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <HeadingTag class="m-0 mt-2 text-[clamp(1.75rem,4vw,2.75rem)] font-black leading-[var(--leading-tight)] text-[var(--color-ink-strong)]">
    {title}
  </HeadingTag>
  {summary && <p class="mt-4 text-lg leading-[var(--leading-normal)] text-[var(--color-ink-soft)]">{summary}</p>}
</div>
