---
interface Props {
  eyebrow?: string;
  title: string;
  summary?: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="m-0 text-sm font-semibold uppercase tracking-normal text-[var(--color-civic-green)]">{eyebrow}</p>}
  <h2 class="m-0 mt-2 text-3xl font-bold leading-tight text-[var(--color-civic-ink)] md:text-4xl">{title}</h2>
  {summary && <p class="mt-4 text-lg text-slate-700">{summary}</p>}
</div>
