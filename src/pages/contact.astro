---
import MainLayout from "../components/layout/MainLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import PageCTA from "../components/sections/PageCTA.astro";
import Alert from "../components/ui/Alert.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import { CONTACT_EMAIL } from "../lib/constants";
import { getPageMeta } from "../lib/seo";
---

<MainLayout meta={getPageMeta("/contact")}>
  <PageHero
    eyebrow="Contact"
    title="Ask a question or join the effort"
    summary="Send a question, volunteer interest, or request to join updates. This form is a launch-ready placeholder until the final submission endpoint and privacy language are reviewed."
    primaryHref={`mailto:${CONTACT_EMAIL}`}
    primaryLabel="Email Melrose RCV"
    secondaryHref="/faq"
    secondaryLabel="Read the FAQ first"
  />

  <section class="section-band bg-white">
    <div class="section-shell grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <form id="contact-form" class="rounded-[var(--radius-4)] border border-[var(--color-line)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-sm)]" method="post">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-bold text-[var(--color-ink)]">
            Name
            <input class="focus-ring rounded-[var(--radius-2)] border border-[var(--color-line-strong)] bg-white px-4 py-3 font-normal" name="name" autocomplete="name" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-[var(--color-ink)]">
            Email
            <input class="focus-ring rounded-[var(--radius-2)] border border-[var(--color-line-strong)] bg-white px-4 py-3 font-normal" name="email" type="email" autocomplete="email" />
          </label>
        </div>
        <label class="mt-4 grid gap-2 text-sm font-bold text-[var(--color-ink)]">
          What are you interested in?
          <select class="focus-ring rounded-[var(--radius-2)] border border-[var(--color-line-strong)] bg-white px-4 py-3 font-normal" name="interest">
            <option>Ask a question</option>
            <option>Join the email list</option>
            <option>Volunteer</option>
            <option>Host a conversation</option>
            <option>Share a source or correction</option>
          </select>
        </label>
        <fieldset class="mt-4 rounded-[var(--radius-3)] border border-[var(--color-line)] p-4">
          <legend class="px-2 text-sm font-black">Volunteer interests</legend>
          <div class="mt-2 grid gap-3 sm:grid-cols-2">
            {["Neighbor conversations", "Source review", "Public meetings", "Design or web help", "Translation or accessibility", "Unsure yet"].map((interest) => (
              <label class="flex items-center gap-3 text-sm font-bold">
                <input class="size-4 accent-[var(--color-blue-700)]" type="checkbox" name="volunteer" value={interest} />
                {interest}
              </label>
            ))}
          </div>
        </fieldset>
        <label class="mt-4 grid gap-2 text-sm font-bold text-[var(--color-ink)]">
          Message
          <textarea class="focus-ring min-h-36 rounded-[var(--radius-2)] border border-[var(--color-line-strong)] bg-white px-4 py-3 font-normal" name="message"></textarea>
        </label>
        <p class="mt-4 text-sm leading-[var(--leading-normal)] text-[var(--color-ink-soft)]">
          Privacy placeholder: before launch, this form needs final retention, consent, list-management, and third-party-tool language.
        </p>
        <div class="mt-5">
          <Button type="submit">Submit placeholder form</Button>
        </div>
      </form>

      <div class="grid gap-4">
        <Alert title="Submission setup pending" tone="caution">
          <p class="m-0">This form preserves the intended user experience. It should not be connected to a live endpoint until privacy and list-management details are reviewed.</p>
        </Alert>
        <Card variant="source" tone="blue">
          <h2 class="text-xl font-black">Prefer email?</h2>
          <p class="mt-3 text-sm text-[var(--color-ink-soft)]">Use the placeholder campaign address until a final contact workflow is configured.</p>
          <p class="mt-4">
            <a class="font-bold text-[var(--color-blue-900)] underline underline-offset-4" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
          </p>
        </Card>
        <Card variant="benefit" tone="green">
          <h2 class="text-xl font-black">Good questions help</h2>
          <p class="mt-3 text-sm text-[var(--color-ink-soft)]">Questions about cost, voting machines, audits, legal authority, and ballot design should be treated as part of the public work.</p>
        </Card>
      </div>
    </div>
  </section>

  <PageCTA
    title="Want to read before reaching out?"
    summary="The FAQ and source page are built for residents who want direct answers and citations before joining the list."
    primaryHref="/faq"
    primaryLabel="Read the FAQ"
    secondaryHref="/sources"
    secondaryLabel="Review sources"
  />
</MainLayout>
