---
import MainLayout from "../components/layout/MainLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import PageCTA from "../components/sections/PageCTA.astro";
import Alert from "../components/ui/Alert.astro";
import Card from "../components/ui/Card.astro";
import SourceNote from "../components/ui/SourceNote.astro";
import { getPageMeta } from "../lib/seo";

const verifiedFacts = [
  {
    title: "The City runs official election information",
    summary:
      "The City of Melrose elections page is the official place for voter registration, polling, vote-by-mail, nomination papers, results, and election administration information.",
    sources: "melrose-elections",
  },
  {
    title: "Melrose has an 11-member City Council",
    summary:
      "The City Council structure documented in the Melrose Charter includes 4 councilors-at-large and 7 ward councilors.",
    sources: "melrose-charter-article-2",
  },
  {
    title: "Municipal offices need office-by-office review",
    summary:
      "Mayor, ward councilor, councilor-at-large, and School Committee contests may raise different legal and counting questions, especially where multi-seat races are involved.",
    sources: "melrose-charter, cambridge-election, mit-irv",
  },
];

const openQuestions = [
  "Which Melrose offices, if any, would be included in a future proposal?",
  "Would the proposal affect preliminary elections, general elections, or both?",
  "How would multi-seat offices be handled, if included?",
  "What equipment, software, reporting, audit, and recount procedures would be required?",
  "What voter education and accessibility plan would be needed before any first use?",
];
---

<MainLayout meta={getPageMeta("/melrose-elections")}>
  <PageHero
    eyebrow="Melrose elections"
    title="Local election context matters"
    summary="Any RCV proposal for Melrose needs to start with the city's actual election structure, official administration, and unanswered implementation questions."
    primaryHref="/home-rule-petition"
    primaryLabel="Read the home rule path"
    secondaryHref="/sources"
    secondaryLabel="Review sources"
    status="This page is informational. Official voting questions should go to the City of Melrose Elections Office."
  />

  <section class="section-band bg-white">
    <div class="section-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Verified local context</p>
        <h2 class="mt-2 text-3xl font-black">Start with official Melrose sources</h2>
        <p class="mt-4 text-lg leading-[var(--leading-normal)] text-[var(--color-ink-soft)]">
          Melrose RCV should not become a substitute for official election administration. The campaign can explain a proposal, but the City remains the source for voter registration, polling places, ballots, results, and election rules.
        </p>
      </div>
      <SourceNote tone="verified" status="Melrose election claims here are limited to City of Melrose, Melrose Charter, eCode360, and Massachusetts Municipal Association sources reviewed on 2026-06-02." />
    </div>
  </section>

  <section class="section-band bg-[var(--color-paper)]">
    <div class="section-shell">
      <h2 class="text-3xl font-black">What is verified now</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {verifiedFacts.map((fact) => (
          <Card variant="source" tone="green" class="h-full">
            <h3 class="text-xl font-black">{fact.title}</h3>
            <p class="mt-3 text-sm leading-[var(--leading-normal)] text-[var(--color-ink-soft)]">{fact.summary}</p>
            <p class="mt-4 text-xs font-bold uppercase text-[var(--color-green-900)]">Sources: {fact.sources}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-white">
    <div class="section-shell grid gap-8 lg:grid-cols-[1fr_0.9fr]">
      <div>
        <p class="eyebrow">Open questions</p>
        <h2 class="mt-2 text-3xl font-black">Facts still need official review before proposal language is final</h2>
        <ul class="mt-6 grid gap-3 p-0">
          {openQuestions.map((question) => (
            <li class="list-none rounded-[var(--radius-3)] border border-[var(--color-line)] bg-[var(--color-surface)] p-4 font-bold text-[var(--color-ink)]">{question}</li>
          ))}
        </ul>
      </div>
      <div class="grid gap-4">
        <Alert title="Do not infer adoption" tone="legal">
          <p class="m-0">Melrose has not adopted RCV. This website describes a civic education effort and a possible legal pathway.</p>
        </Alert>
        <Alert title="Office scope is undecided" tone="caution">
          <p class="m-0">The site should not say RCV would apply to every local office unless petition language and legal review confirm that scope.</p>
        </Alert>
      </div>
    </div>
  </section>

  <PageCTA
    title="Connect local context to the legal path"
    summary="A Melrose proposal would need to explain which offices are covered, what state authority is needed, and how voters would learn the system."
    primaryHref="/home-rule-petition"
    primaryLabel="Read the home rule path"
    secondaryHref="/faq"
    secondaryLabel="Read common questions"
  />
</MainLayout>
