---
import { benefits } from "../content/data/benefits";
import MainLayout from "../components/layout/MainLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import PageCTA from "../components/sections/PageCTA.astro";
import Alert from "../components/ui/Alert.astro";
import Card from "../components/ui/Card.astro";
import SourceNote from "../components/ui/SourceNote.astro";
import { getPageMeta } from "../lib/seo";
---

<MainLayout meta={getPageMeta("/why-melrose")}>
  <PageHero
    eyebrow="Why Melrose?"
    title="Why consider ranked-choice voting here?"
    summary="Melrose RCV makes the case for a careful local conversation: more expressive ballots, less vote-splitting pressure, and stronger voter education, paired with honest limits and open questions."
    primaryHref="/home-rule-petition"
    primaryLabel="Understand the home rule path"
    secondaryHref="/contact"
    secondaryLabel="Join updates"
  />

  <section class="section-band bg-white">
    <div class="section-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Local civic values</p>
        <h2 class="mt-2 text-3xl font-black">A practical question for neighbors</h2>
        <p class="mt-4 text-lg text-[var(--color-ink-soft)]">
          The question is not whether RCV is perfect. It is whether Melrose residents want to explore an election method that lets voters express backup choices while asking hard questions about implementation, cost, transparency, and trust.
        </p>
      </div>
      <Card variant="source" tone="green">
        <h3 class="text-xl font-black">Melrose context</h3>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Melrose has a mayor-council form of government, and the City Council has 11 members: 4 councilors-at-large and 7 ward councilors.
        </p>
        <p class="mt-4 text-xs font-bold uppercase text-[var(--color-green-900)]">Sources: mma-melrose, melrose-charter-article-2</p>
      </Card>
    </div>
  </section>

  <section class="section-band bg-[var(--color-paper)]">
    <div class="section-shell">
      <p class="eyebrow">Possible benefits</p>
      <h2 class="mt-2 text-3xl font-black">Supporter arguments, with caveats</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {benefits.map((benefit, index) => (
          <Card variant="benefit" tone={index % 2 === 0 ? "green" : "plain"}>
            <h3 class="text-xl font-black">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-[var(--leading-normal)] text-[var(--color-ink-soft)]">{benefit.summary}</p>
            {benefit.sourceIds && <p class="mt-4 text-xs font-bold uppercase text-[var(--color-green-900)]">Sources: {benefit.sourceIds.join(", ")}</p>}
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-white">
    <div class="section-shell grid gap-5 lg:grid-cols-3">
      <Alert title="Do not overpromise" tone="caution">
        <p class="m-0">RCV does not guarantee higher turnout, lower costs, better candidates, more civil campaigns, or perfect majority outcomes.</p>
      </Alert>
      <Alert title="Implementation matters" tone="legal">
        <p class="m-0">Melrose would need answers on equipment, ballot design, tabulation, voter education, results, audits, recounts, and costs.</p>
      </Alert>
      <SourceNote tone="verified" status="Benefits and caveats are grounded in NCSL, MIT Election Lab, Center for Civic Design, and RCV Resource Center research." />
    </div>
  </section>

  <PageCTA
    title="The next question is legal and civic"
    summary="If Melrose wants to pursue RCV, the pathway would likely run through a Massachusetts home rule petition and state legislative review."
    primaryHref="/home-rule-petition"
    primaryLabel="Read the home rule path"
    secondaryHref="/melrose-elections"
    secondaryLabel="Review Melrose context"
  />
</MainLayout>
