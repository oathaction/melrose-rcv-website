---
import MainLayout from "../components/layout/MainLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import PageCTA from "../components/sections/PageCTA.astro";
import Alert from "../components/ui/Alert.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import SourceNote from "../components/ui/SourceNote.astro";
import { getPageMeta } from "../lib/seo";
---

<MainLayout meta={getPageMeta("/what-is-rcv")}>
  <PageHero
    eyebrow="RCV basics"
    title="What is ranked-choice voting?"
    summary="Ranked-choice voting lets voters rank candidates in order of preference instead of choosing only one. Later rankings are backup choices if an earlier-ranked candidate is eliminated."
    primaryHref="/how-it-works"
    primaryLabel="See how RCV works"
    secondaryHref="/faq"
    secondaryLabel="Read common questions"
  />

  <section class="section-band bg-white">
    <div class="section-shell grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="eyebrow">Plain definition</p>
        <h2 class="mt-2 text-3xl font-black">Ranking gives voters more than one preference</h2>
        <p class="mt-4 text-lg text-[var(--color-ink-soft)]">
          In a ranked-choice election, a voter can mark a first choice, second choice, third choice, and additional choices if the ballot allows. The first choice is counted first.
        </p>
        <div class="mt-6">
          <SourceNote tone="verified" status="Definition grounded in NCSL, NYC Votes, Minneapolis, and MIT Election Lab source reviews." />
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        {[
          ["1", "First choice", "The candidate you most prefer."],
          ["2", "Backup choice", "Can count if your first choice is eliminated."],
          ["3", "Another option", "Still not an extra active vote."],
        ].map(([number, title, summary]) => (
          <Card tone="blue" class="h-full">
            <p class="m-0 text-4xl font-black text-[var(--color-blue-700)]">{number}</p>
            <h3 class="mt-3 text-xl font-black">{title}</h3>
            <p class="mt-2 text-sm text-[var(--color-ink-soft)]">{summary}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-[var(--color-paper)]">
    <div class="section-shell grid gap-5 md:grid-cols-2">
      <Card variant="source">
        <h2 class="text-2xl font-black">Single-winner RCV</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          For one-seat offices, RCV is often counted as instant-runoff voting. If no candidate reaches the threshold at first, the lowest candidate is eliminated and ballots can transfer to each voter's next ranked continuing candidate.
        </p>
        <p class="mt-4 text-xs font-bold uppercase text-[var(--color-blue-900)]">Sources: mit-irv, ncsl-rcv</p>
      </Card>
      <Card variant="source" tone="green">
        <h2 class="text-2xl font-black">Multi-winner ranked voting</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Ranked ballots can also be counted in multi-winner systems. Cambridge, Massachusetts uses proportional representation for City Council and School Committee, which is not the same as a single-winner Melrose proposal.
        </p>
        <p class="mt-4 text-xs font-bold uppercase text-[var(--color-green-900)]">Sources: cambridge-election, mit-irv</p>
      </Card>
    </div>
  </section>

  <section class="section-band bg-white">
    <div class="section-shell grid gap-8 lg:grid-cols-[1fr_0.85fr]">
      <div>
        <p class="eyebrow">What voters do</p>
        <h2 class="mt-2 text-3xl font-black">You can rank backups, but you do not have to rank everyone</h2>
        <p class="mt-4 text-lg text-[var(--color-ink-soft)]">
          Most official RCV voter education examples explain that voters may rank fewer candidates than the ballot allows. The tradeoff is that if every candidate you rank is eliminated, your ballot may have no remaining continuing choice in later rounds.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href="/how-it-works">Learn the counting steps</Button>
          <Button href="/myths-and-facts" variant="secondary">Read myths and facts</Button>
        </div>
      </div>
      <Alert title="Melrose-specific rules need review" tone="legal">
        <p class="m-0">The number of rankings, ballot layout, write-in treatment, skipped rankings, repeated rankings, and overvote rules would need official election-administration and legal review before public voter instructions are final.</p>
      </Alert>
    </div>
  </section>

  <PageCTA
    title="Ready to see the count in action?"
    summary="The next page walks through first choices, elimination rounds, transfers, and exhausted ballots in plain language."
    primaryHref="/how-it-works"
    primaryLabel="See how RCV works"
    secondaryHref="/faq"
    secondaryLabel="Read the FAQ"
  />
</MainLayout>
